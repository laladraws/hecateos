# HecateOS .gitignore

# Llaves privadas de cosign — NUNCA commitear
cosign.key
*.key

# Outputs locales de build
output/
build/
*.iso

# Editor
.vscode/
.idea/
*.swp
*~

# macOS
.DS_Store

# Archivos grandes de assets (usar Git LFS o CDN)
*.png
*.jpg
*.jpeg
*.webp
# Excepción: el SVG del logo sí va en el repo
!config/files/usr/share/pixmaps/hecate-os.svg
!config/files/usr/share/backgrounds/hecate-os/*.png
!config/files/usr/share/backgrounds/hecate-os/*.png
!config/files/usr/share/backgrounds/hecate-os/*.jpg
!config/files/usr/share/pixmaps/hecate-os.png
!config/files/usr/share/pixmaps/hecate-os-256.png