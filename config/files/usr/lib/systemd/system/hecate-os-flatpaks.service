[Unit]
Description=HecateOS Flatpak Installation
After=network-online.target flatpak-system-helper.service multi-user.target
Wants=network-online.target
ConditionPathExists=!/etc/hecate-os-flatpaks-done

[Service]
Type=oneshot
ExecStart=/usr/libexec/hecate-os-install-flatpaks
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target